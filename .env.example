# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service Role Key (required for admin operations like deleting users - keep secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Development
NEXT_PRIVATE_DEV_CORS_ORIGIN=*

# AI API Configuration
# Choose your AI provider: openai, claude, deepseek, or mock (default: mock)
NEXT_PUBLIC_AI_PROVIDER=mock

# OpenAI Configuration
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here
NEXT_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Claude (Anthropic) Configuration
NEXT_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here
NEXT_PUBLIC_CLAUDE_MODEL=claude-3-haiku-20240307

# DeepSeek Configuration
NEXT_PUBLIC_DEEPSEEK_API_KEY=your_deepseek_api_key_here
NEXT_PUBLIC_DEEPSEEK_MODEL=deepseek-chat